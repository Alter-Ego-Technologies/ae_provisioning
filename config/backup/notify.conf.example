# Backup success/failure notification recipients (space-separated)
# Used by: sync_nextcloud, sync_cyberpanel, sync_standalone, sync_to_cloud
# Mailcow: one daily summary at 6:00 (no per-run emails)
BACKUP_NOTIFY_TO="admins@alteregotech.com admins@clearpointreporting.com"

# From address (must match your SMTP relay /etc/msmtprc or relay may reject)
BACKUP_NOTIFY_FROM="server-alerts@alteregotech.com"

# Timezone for email timestamps (e.g. America/New_York); leave empty or omit for server default (UTC)
# BACKUP_NOTIFY_TZ="America/New_York"
