nextcloud_restart() {
  if docker ps --format '{{.Names}}' | grep -q nextcloud; then
    docker restart $(docker ps --format '{{.Names}}' | grep nextcloud)
  elif systemctl list-units --type=service | grep -q nextcloud; then
    sudo systemctl restart nextcloud
  else
    echo "No Nextcloud container or service found."
  fi
}

nextcloud_status() {
  if docker ps --format '{{.Names}}' | grep -q nextcloud; then
    docker ps | grep nextcloud
  elif systemctl list-units --type=service | grep -q nextcloud; then
    sudo systemctl status nextcloud
  else
    echo "No Nextcloud container or service found."
  fi
}

# --- Docker Helpers ---
docker_ps() {
  docker ps --format 'table {{.Names}}	{{.Status}}	{{.Ports}}'
}

docker_logs() {
  if [ -z "$1" ]; then
    echo "Usage: docker_logs <container>"
    return 1
  fi
  docker logs --tail=100 -f "$1"
}

docker_exec() {
  if [ -z "$1" ]; then
    echo "Usage: docker_exec <container> [command]"
    return 1
  fi
  shift
  docker exec -it "$1" "$@"
}

# --- CyberPanel Control ---
cyberpanel_restart() {
