# === Certificate and Service Control Helpers ===

# --- Certificate Inspection ---
cert_check() {
  DOMAIN=$1
  if [[ -z "$DOMAIN" ]]; then
    echo "Usage: cert_check <domain>"
    return 1
  fi
  echo | openssl s_client -connect ${DOMAIN}:443 -servername ${DOMAIN} 2>/dev/null | openssl x509 -noout -subject -issuer -dates
}

# --- Web Server Control (auto-detects) ---
web_restart() {
  if systemctl list-units --type=service | grep -q 'lsws'; then
    sudo systemctl restart lsws
  elif systemctl list-units --type=service | grep -q 'nginx'; then
    sudo systemctl restart nginx
  elif systemctl list-units --type=service | grep -q 'apache2'; then
    sudo systemctl restart apache2
  else
    echo "No known web server found (lsws, nginx, apache2)."
  fi
}

web_status() {
  if systemctl list-units --type=service | grep -q 'lsws'; then
    sudo systemctl status lsws
  elif systemctl list-units --type=service | grep -q 'nginx'; then
    sudo systemctl status nginx
  elif systemctl list-units --type=service | grep -q 'apache2'; then
    sudo systemctl status apache2
  else
    echo "No known web server found (lsws, nginx, apache2)."
  fi
}

# --- Mail Server Control (auto-detects) ---
mail_restart() {
  if systemctl list-units --type=service | grep -q 'mailcow'; then
    cd /opt/mailcow-dockerized && docker compose restart
  elif systemctl list-units --type=service | grep -q 'postfix'; then
    sudo systemctl restart postfix
    sudo systemctl restart dovecot
  else
    echo "No known mail server found (mailcow, postfix, dovecot)."
  fi
}

mail_status() {
  if systemctl list-units --type=service | grep -q 'mailcow'; then
    cd /opt/mailcow-dockerized && docker compose ps
  elif systemctl list-units --type=service | grep -q 'postfix'; then
    sudo systemctl status postfix
    sudo systemctl status dovecot
  else
    echo "No known mail server found (mailcow, postfix, dovecot)."
  fi
}

# --- Webmail Quick Access (prints URL) ---
webmail_url() {
  if [ -d /opt/mailcow-dockerized ]; then
    echo "https://$(hostname -f)/SOGo/"
  else
    echo "Webmail location not detected."
  fi
}
