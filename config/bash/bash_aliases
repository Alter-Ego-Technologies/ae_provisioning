## Firewall ##

# Quick status checks
alias firewall-list='ufw status numbered'
alias firewall-status='ufw status'

# Enable/Disable firewall
alias firewall-enable='ufw enable'
alias firewall-disable='ufw disable'
alias firewall-restart='ufw reload'

# Dynamic helper function
firewall() {
  case "$1" in
    allow) ufw allow "$2";;
    deny) ufw deny "$2";;
    delete) ufw delete "$2";;
    status) ufw status;;
    list) ufw status numbered;;
    enable) ufw enable;;
    disable) ufw disable;;
    reload) ufw reload;;
    help|"")
      echo "Usage: firewall [allow|deny|delete|status|list|enable|disable|reload] [port/rule]"
      ;;
    *) echo "Unknown command: $1";;
  esac
}


## 🧾 Log Viewer Function ##
log() {
  local mode="tail"
  local lines=50

  if [[ "$1" == "watch" ]]; then
    mode="watch"
    shift
  fi

  case "$1" in
    error|web-error)
      [[ "$mode" == "watch" ]] && tail -f /usr/local/lsws/logs/error.log || tail -n $lines /usr/local/lsws/logs/error.log
      ;;
    access|web-access)
      [[ "$mode" == "watch" ]] && tail -f /usr/local/lsws/logs/access.log || tail -n $lines /usr/local/lsws/logs/access.log
      ;;
    mailcow)
      [[ "$mode" == "watch" ]] && tail -f /var/log/mail.log || tail -n $lines /var/log/mail.log
      ;;
    ftp)
      [[ "$mode" == "watch" ]] && tail -f /var/log/pure-ftpd/pure-ftpd.log || tail -n $lines /var/log/pure-ftpd/pure-ftpd.log
      ;;
    cyberpanel)
      [[ "$mode" == "watch" ]] && tail -f /home/cyberpanel/error-logs.txt || tail -n $lines /home/cyberpanel/error-logs.txt
      ;;
    help|"")
      echo "Usage: log [watch] <error|access|ftp|mailcow|cyberpanel>"
      ;;
    *)
      echo "Unknown log type: $1"
      ;;
  esac
}
