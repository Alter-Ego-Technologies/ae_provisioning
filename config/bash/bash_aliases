################ Aliases ################################
# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    #alias dir='dir --color=auto'
    #alias vdir='vdir --color=auto'

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# Directory Listings #
alias ll='ls -alF' #Filetypes and permissions
alias la='ls -A' #Lists all except . and ..
alias l='ls -CF' # Clean column based list

# Sort by time modified
alias lt='ls -lt'          # Sort by modification time, newest first
alias ltr='ls -ltr'        # Time sorted, reverse (oldest at bottom)

# Human-readable sizes
alias lh='ls -lh'          # Long list, human file sizes
alias lsh='ls -sh'         # Show size in human-readable, short list

# Only dirs
alias lsd='ls -l | grep "^d"'  # List only directories

# Tree style (needs `tree` installed)
alias lst='tree -L 1 --dirsfirst'  # Top-level folder view


